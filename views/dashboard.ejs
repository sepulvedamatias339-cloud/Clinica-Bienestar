<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>

    <style>

        body{
            font-family: Arial;
            margin:40px;
            background:#f4f4f4;
        }

        h1{
            color:#2e8b57;
        }

        .topbar{
            display:flex;
            justify-content:space-between;
            align-items:center;
        }

        table{
            width:100%;
            border-collapse:collapse;
            background:white;
            margin-top:20px;
        }

        th, td{
            border:1px solid #ccc;
            padding:10px;
            text-align:center;
        }

        th{
            background:#2e8b57;
            color:white;
        }

        .btn{
            background:#2e8b57;
            color:white;
            padding:10px 15px;
            text-decoration:none;
            border-radius:5px;
        }

        .eliminar{
            background:red;
            color:white;
            padding:5px 10px;
            text-decoration:none;
            border-radius:5px;
        }

        .logout{
            background:#444;
            color:white;
            padding:10px 15px;
            text-decoration:none;
            border-radius:5px;
        }

    </style>

</head>
<body>

<div class="topbar">

    <h1>Pacientes Clínica Bienestar</h1>

    <a class="logout" href="/logout">
        Cerrar Sesión
    </a>

</div>

<br>

<a class="btn" href="/agregar">
    Agregar Paciente
</a>

<br><br>

<table>

<tr>
    <th>ID</th>
    <th>Nombre</th>
    <th>Correo</th>
    <th>Acciones</th>
</tr>

<% pacientes.forEach(function(paciente){ %>

<tr>

    <td><%= paciente.id %></td>

    <td><%= paciente.nombre %></td>

    <td><%= paciente.correo %></td>

    <td>

        <a
            class="eliminar"
            href="/eliminar/<%= paciente.id %>"
        >
            Eliminar
        </a>

    </td>

</tr>

<% }) %>

</table>

</body>
</html>